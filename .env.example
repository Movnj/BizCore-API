# ============================================
# BizCore API — Environment Variables
# Copy ke .env dan isi nilainya
# JANGAN push .env ke GitHub!
# ============================================

# Supabase
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_KEY=your-service-role-key-here

# Server
PORT=3000
NODE_ENV=development

# CORS — pisah dengan koma
ALLOWED_ORIGINS=https://umkm-pro.biz.id,http://localhost:5173

# API
API_VERSION=v1
API_NAME=BizCore API
